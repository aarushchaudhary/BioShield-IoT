<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for local/private IPs (development) -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Private network ranges - specific IPs -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Localhost variants -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    
    <!-- Allow cleartext for any IP starting with 192.168.x.x -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168</domain>
    </domain-config>
    
    <!-- Allow cleartext for any IP starting with 10.x.x.x -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10</domain>
    </domain-config>
    
    <!-- Allow cleartext for any IP starting with 172.16.x.x to 172.31.x.x -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">172</domain>
    </domain-config>
    
    <!-- All other domains require HTTPS (production) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">example.com</domain>
    </domain-config>
</network-security-config>
