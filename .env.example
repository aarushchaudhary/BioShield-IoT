# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bioshield

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security — PASETO token signing key (generate a secure 32-byte hex string)
PASETO_SECRET_KEY=

# AES-256 master key for encrypting key vault entries (32-byte hex string)
AES_MASTER_KEY=

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000

# Environment
ENVIRONMENT=development
